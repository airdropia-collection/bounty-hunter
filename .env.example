# ---------------------------------------------------------------
# Bounty Hunter — example environment
# Copy to `.env` for local dev, or set as GitHub Actions secrets.
# NEVER commit real values.
# ---------------------------------------------------------------

# === AI APIs (both free tier) ===
GEMINI_API_KEY=
GROQ_API_KEY=

# === GitHub (for Issue creation + PR submission) ===
# Fine-grained PAT with: contents:write, issues:write, pull-requests:write, workflows:write
GH_PAT=
GH_REPO=airdropia-collection/bounty-hunter

# === Web3 RPC (free public endpoints) ===
# Mainnet
ETH_RPC_URL=https://eth.llamarpc.com
# Alternative free endpoints (rotate if rate-limited):
#   https://rpc.ankr.com/eth
#   https://ethereum.publicnode.com
#   https://1rpc.io/eth

# === Optional: Etherscan API (for contract source verification) ===
# Free tier: 5 calls/sec, 100k/day
ETHERSCAN_API_KEY=

# === Optional: Wallet address for payouts (NEVER private key) ===
WALLET_ADDRESS=

# === Optional: Telegram Bot (for live notifications) ===
# 1. Create bot via @BotFather on Telegram → get BOT_TOKEN
# 2. Send a message to your bot → get CHAT_ID
# 3. Add both as GitHub Secrets
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Scraper settings ===
# Max bounties to analyze per run
MAX_BOUNTIES_PER_RUN=5
# Min payout (USD) to consider — Cycle 23: lowered from $500 to $1.
# Bot's account is at $0; success rate / CV building > bounty size.
# Pre-qualification still applies (real-asset, parent issue open, maintainer active, code match).
MIN_PAYOUT_USD=1
# Max contest duration (days) — skip if too short
MAX_CONTEST_DAYS=30

# === AI settings ===
# Run doubt-driven review on High/Critical findings (recommended: true)
ENABLE_DOUBT_REVIEW=true
# Max tokens per AI call (stay within free tier)
AI_MAX_TOKENS=8192

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=rich
